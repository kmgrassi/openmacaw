# ============================================================================
# REQUIRED — the stack will not boot / log in without these four values.
#
# Local Supabase:  run `supabase start` + `supabase status` in platform/ and
#                  copy the API URL, service_role key, and anon key here.
#                  (URL is typically http://127.0.0.1:54321)
# Hosted Supabase: copy the same values from the project dashboard.
# ============================================================================

# Server-side Supabase access (platform API).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Browser Supabase access (web app login). Keep the URL aligned with
# SUPABASE_URL above for local runs.
VITE_SUPABASE_DEV_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_DEV_ANON_KEY=your-dev-anon-key

# ============================================================================
# OPTIONAL — everything below is feature-gated or has working defaults.
# ============================================================================

# Supabase project ref — used by schema-sync tooling (db:schema:sync), not by
# the running stack.
SUPABASE_PROJECT_ID=your-project-ref

# Which browser Supabase target to use: `dev` (above) or `prod` (below).
VITE_SUPABASE_ENV=dev
VITE_SUPABASE_PROD_URL=
VITE_SUPABASE_PROD_ANON_KEY=

# Service ports and URLs. `./openmacaw run` sets these automatically; only
# override for nonstandard setups.
PORT=3100
ORCHESTRATOR_BASE_URL=http://127.0.0.1:4000
LAUNCHER_BASE_URL=http://127.0.0.1:4100
ORCHESTRATOR_REQUEST_TIMEOUT_MS=15000
LAUNCHER_REQUEST_TIMEOUT_MS=15000
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
VITE_BROKER_BASE=http://127.0.0.1:3100
VITE_GATEWAY_WS_URL=ws://127.0.0.1:3100/ws
VITE_OPENMACAW_APP_BASE_URL=https://app.openmacaw.ai

# Local login shortcut. These values render a "Use dev credentials" /
# "Use prod test credentials" button on the login page in development only
# (gated on `import.meta.env.DEV`). Which pair we surface follows
# `VITE_SUPABASE_ENV` above. Neither pair auto-signs you in; you click the
# button.
VITE_DEV_LOGIN_EMAIL=
VITE_DEV_LOGIN_PASSWORD=
VITE_PROD_LOGIN_EMAIL=
VITE_PROD_LOGIN_PASSWORD=

# Workspace defaults for first-run setup.
WORK_ITEM_DEFAULT_WORKSPACE_ID=
SETUP_DEFAULT_WORKSPACE_NAME=Personal Workspace
SETUP_DEFAULT_MANAGER_MODEL=openai/gpt-5.2

# GitHub integration (webhook intake + PR automation). Leave blank to disable.
GITHUB_WEBHOOK_SECRET=
GITHUB_API_TOKEN=
GITHUB_REPO_WORKSPACE_MAP=

# Linear integration (webhook intake). Leave blank to disable.
LINEAR_WEBHOOK_SECRET=
LINEAR_API_KEY=
LINEAR_PROJECT_WORKSPACE_MAP=
LINEAR_TEAM_WORKSPACE_MAP=

# Container coding execution rollout. Keep local_helper_default for rollback.
CONTAINER_EXECUTION_ROUTING_MODE=local_helper_default
CONTAINER_EXECUTION_ALLOWLIST_WORKSPACE_IDS=
CONTAINER_EXECUTION_ROLLOUT_PERCENTAGE=0

# Model catalog provider discovery. Leave blank to skip that provider.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
PERPLEXITY_API_KEY=

# Azure OpenAI lists deployments, so it needs both a key and resource endpoint.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-01
