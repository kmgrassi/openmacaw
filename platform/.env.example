PORT=3100
ORCHESTRATOR_BASE_URL=http://127.0.0.1:4000
LAUNCHER_BASE_URL=http://127.0.0.1:4100
ORCHESTRATOR_REQUEST_TIMEOUT_MS=15000
LAUNCHER_REQUEST_TIMEOUT_MS=15000
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Server-side Supabase access.
SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Browser Supabase access. Keep this aligned with SUPABASE_URL above for local runs.
VITE_SUPABASE_ENV=dev
VITE_SUPABASE_DEV_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_DEV_ANON_KEY=your-dev-anon-key
VITE_SUPABASE_PROD_URL=https://your-prod-project.supabase.co
VITE_SUPABASE_PROD_ANON_KEY=your-prod-anon-key

# Local dev client -> local API.
VITE_BROKER_BASE=http://127.0.0.1:3100
VITE_GATEWAY_WS_URL=ws://127.0.0.1:3100/ws

# Optional local login shortcut. These values render a "Use dev credentials" /
# "Use prod test credentials" button on the login page in development only
# (gated on `import.meta.env.DEV`). Which pair we surface follows
# `VITE_SUPABASE_ENV` above. Neither pair auto-signs you in; you click the button.
VITE_DEV_LOGIN_EMAIL=
VITE_DEV_LOGIN_PASSWORD=
VITE_PROD_LOGIN_EMAIL=
VITE_PROD_LOGIN_PASSWORD=

WORK_ITEM_DEFAULT_WORKSPACE_ID=your-default-workspace-id
SETUP_DEFAULT_WORKSPACE_NAME=Personal Workspace
SETUP_DEFAULT_MANAGER_MODEL=openai/gpt-5.2
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
GITHUB_API_TOKEN=your-github-api-token
GITHUB_REPO_WORKSPACE_MAP={"your-org/your-repo":"your-workspace-id"}
LINEAR_WEBHOOK_SECRET=your-linear-webhook-secret
LINEAR_API_KEY=your-linear-api-key
LINEAR_PROJECT_WORKSPACE_MAP={"linear-project-uuid":"your-workspace-id"}
LINEAR_TEAM_WORKSPACE_MAP={"linear-team-uuid":"your-workspace-id"}

# Model catalog provider discovery. Leave blank to skip that provider.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
PERPLEXITY_API_KEY=

# Azure OpenAI lists deployments, so it needs both a key and resource endpoint.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-01
