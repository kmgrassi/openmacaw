# Local development now loads env from the repository root `.env`.
# This app-local file is retained only as a reference for API-specific keys.
PORT=3100
ORCHESTRATOR_BASE_URL=http://127.0.0.1:4000
LAUNCHER_BASE_URL=http://127.0.0.1:4100
ORCHESTRATOR_REQUEST_TIMEOUT_MS=15000
LAUNCHER_REQUEST_TIMEOUT_MS=15000
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
WORK_ITEM_DEFAULT_WORKSPACE_ID=your-default-workspace-id
SETUP_DEFAULT_WORKSPACE_NAME=Personal Workspace
SETUP_DEFAULT_MANAGER_MODEL=openai/gpt-5.2
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
GITHUB_API_TOKEN=your-github-api-token
GITHUB_REPO_WORKSPACE_MAP={"your-org/your-repo":"your-workspace-id"}
LINEAR_WEBHOOK_SECRET=your-linear-webhook-secret
LINEAR_API_KEY=your-linear-api-key
LINEAR_PROJECT_WORKSPACE_MAP={"linear-project-uuid":"your-workspace-id"}
LINEAR_TEAM_WORKSPACE_MAP={"linear-team-uuid":"your-workspace-id"}

# Container coding execution rollout. Keep local_helper_default for rollback.
CONTAINER_EXECUTION_ROUTING_MODE=local_helper_default
CONTAINER_EXECUTION_ALLOWLIST_WORKSPACE_IDS=
CONTAINER_EXECUTION_ROLLOUT_PERCENTAGE=0

# Model catalog provider discovery. Leave blank to skip that provider.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
PERPLEXITY_API_KEY=

# Azure OpenAI lists deployments, so it needs both a key and resource endpoint.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-01
