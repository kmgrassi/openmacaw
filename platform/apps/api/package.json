{
  "name": "symphony-express-server",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript Express gateway for Symphony orchestration endpoints",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "local": "tsx src/index.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm test",
    "bootstrap:backend": "bash scripts/bootstrap-backend.sh",
    "backfill:linear-projects": "tsx scripts/backfill-linear-projects.ts",
    "debug:ws-smoke": "tsx scripts/ws-smoke.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1030.0",
    "@harper/plan-schema": "file:../../packages/plan-schema",
    "@kmgrassi/supabase-schema": "file:../../packages/supabase-schema",
    "@supabase/supabase-js": "^2.104.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.7.4",
    "@types/ws": "^8.18.1",
    "eslint": "^9.12.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0",
    "vitest": "^2.1.2"
  }
}
