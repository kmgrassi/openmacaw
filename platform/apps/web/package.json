{
  "name": "harper-openclaw-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm run guard:supabase && tsc -b && vite build",
    "guard:supabase": "node scripts/guard-supabase-browser-api.mjs",
    "preview": "vite preview",
    "dev:aws-local": "pnpm run dev:local",
    "dev:local": "VITE_BROKER_BASE=http://127.0.0.1:3100 VITE_GATEWAY_WS_URL=ws://127.0.0.1:3100/ws vite --host 127.0.0.1 --port 5173",
    "supabase:schema:sync": "pnpm -C ../.. run supabase:schema:sync"
  },
  "dependencies": {
    "@harper/plan-schema": "file:../../packages/plan-schema",
    "@kmgrassi/supabase-schema": "file:../../packages/supabase-schema",
    "@noble/ed25519": "^3.0.0",
    "@supabase/supabase-js": "^2.49.4",
    "@tanstack/query-broadcast-client-experimental": "^5.100.10",
    "@tanstack/react-query": "^5.100.10",
    "clsx": "^2.1.1",
    "dompurify": "^3.2.4",
    "marked": "^15.0.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.13.2",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2",
    "vite": "^6.3.2",
    "vitest": "2.1.9"
  }
}
