# Local development now loads env from the repository root `.env`.
# This app-local file is retained only as a reference for web-specific keys.

# Supabase target selection
# Set to `dev` for local/development work, or `prod` to point the client at production.
VITE_SUPABASE_ENV=dev

# Development Supabase project
VITE_SUPABASE_DEV_URL=https://your-dev-project.supabase.co
VITE_SUPABASE_DEV_ANON_KEY=your-dev-anon-key

# Production Supabase project
VITE_SUPABASE_PROD_URL=https://your-prod-project.supabase.co
VITE_SUPABASE_PROD_ANON_KEY=your-prod-anon-key

# Legacy single-environment fallback variables remain supported.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Local dev client -> local API
VITE_BROKER_BASE=http://localhost:3100
VITE_OPENMACAW_APP_BASE_URL=https://app.openmacaw.ai
VITE_WORKER_BRIDGE_DEFAULT_CWD=/tmp/openmacaw-workspaces/example

# Optional local login shortcut. These values render a "Use dev credentials" /
# "Use prod test credentials" button on the login page in development only
# (the button is gated on `import.meta.env.DEV`). The pair we surface follows
# `VITE_SUPABASE_ENV` above — set both pairs if you flip the env back and forth.
# These never sign in automatically; you still have to click the button.
VITE_DEV_LOGIN_EMAIL=
VITE_DEV_LOGIN_PASSWORD=
VITE_PROD_LOGIN_EMAIL=
VITE_PROD_LOGIN_PASSWORD=

# Optional local-dev model credential autofill. When set, credential forms show
# a "Use dev credentials" button; saving still goes through the normal API path.
VITE_DEV_OPENAI_API_KEY=
VITE_DEV_ANTHROPIC_API_KEY=
VITE_DEV_XAI_API_KEY=
VITE_DEV_GEMINI_API_KEY=
VITE_DEV_MISTRAL_API_KEY=
VITE_DEV_GROQ_API_KEY=
VITE_DEV_OPENROUTER_API_KEY=
VITE_DEV_TOGETHER_API_KEY=
VITE_DEV_PERPLEXITY_API_KEY=
VITE_DEV_AZURE_OPENAI_API_KEY=
VITE_DEV_OPENAI_CODEX_ACCESS_TOKEN=
