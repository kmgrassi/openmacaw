{
  "name": "@kmgrassi/supabase-schema",
  "version": "0.0.0",
  "description": "Published Supabase generated schema types consumed by Platform and Runtime.",
  "type": "module",
  "files": [
    "dist",
    "src/database.types.ts"
  ],
  "exports": {
    ".": {
      "types": "./src/database.types.ts",
      "default": "./dist/database.types.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "~5.7.2"
  }
}
