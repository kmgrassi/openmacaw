project_name = "openmacaw"
environment  = "dev"
aws_region   = "us-east-1"

foundation_state_bucket = "YOUR_TERRAFORM_STATE_BUCKET"
foundation_state_key    = "openmacaw/dev/container-execution/foundation/terraform.tfstate"
foundation_state_region = "us-east-1"

ecs_cluster_arn   = "arn:aws:ecs:us-east-1:123456789012:cluster/openmacaw-dev"
vpc_id            = "vpc_REPLACE_ME"
private_subnet_ids = ["subnet_REPLACE_ME"]

executor_image_tag = "main"
allowed_secret_arns = []
egress_cidr_blocks  = ["0.0.0.0/0"]

# Route each executor private route table through the Network Firewall endpoint
# in the matching firewall subnet so the FQDN allowlist is actually enforced.
network_firewall_protected_route_table_map = {
  "rtb_REPLACE_ME" = "subnet_REPLACE_ME"
}

enable_container_smoke_schedule = false
container_smoke_schedule_expression = "rate(15 minutes)"
container_smoke_commands = {
  task_launch               = "echo configure-task-launch-smoke"
  log_split                 = "echo configure-log-split-smoke"
  egress_allow              = "echo configure-egress-allow-smoke"
  egress_deny               = "echo configure-egress-deny-smoke"
  secret_injection          = "echo configure-secret-injection-smoke"
  sts_scope_positive        = "echo configure-sts-positive-smoke"
  sts_scope_negative        = "echo configure-sts-negative-smoke"
  vpc_endpoint_reachability = "echo configure-vpc-endpoint-smoke"
  queue_round_trip          = "echo configure-queue-round-trip-smoke"
  cancellation              = "echo configure-cancellation-smoke"
  end_to_end                = "echo configure-end-to-end-smoke"
}
