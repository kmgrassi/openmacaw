aws_region       = "us-east-1"
project_name     = "openmacaw"
environment_name = "dev"

service_name        = "openmacaw-launcher-dev"
ecr_repository_name = "openmacaw-dev-runtime-orchestrator"
ecr_repository_uri  = "123456789012.dkr.ecr.us-east-1.amazonaws.com/openmacaw-dev-runtime-orchestrator"
image_tag           = "main"

shared_platform_state_enabled = true
shared_platform_state_bucket  = "YOUR_SHARED_PLATFORM_STATE_BUCKET"
shared_platform_state_key     = "openmacaw/shared/terraform.tfstate"
shared_platform_state_region  = "us-east-1"

create_ecs_cluster        = false
existing_ecs_cluster_name = "openmacaw-dev"

container_port = 4100
desired_count  = 1
task_cpu       = 1024
task_memory    = 2048

service_discovery_namespace    = "openmacaw-dev.local"
service_discovery_service_name = "openmacaw-launcher-dev"

enable_efs          = false
workspace_mount_path = "/tmp/openmacaw_workspaces"

supabase_url        = ""
supabase_anon_key   = ""
supabase_jwt_secret = ""
supabase_service_role_key_ssm_arn = ""
