{
  "terraform_backend": {
    "bucket": "YOUR_EXISTING_OPENCLAW_TERRAFORM_STATE_BUCKET",
    "key": "openclaw/prod/terraform.tfstate",
    "region": "us-east-1",
    "dynamodb_table": "YOUR_EXISTING_OPENCLAW_TERRAFORM_LOCK_TABLE",
    "encrypt": true
  },
  "terraform_vars": {
    "aws_region": "us-east-1",
    "platform_state_bucket": "YOUR_SHARED_PLATFORM_STATE_BUCKET",
    "platform_state_key": "YOUR_SHARED_PLATFORM_STATE_KEY",
    "platform_state_region": "us-east-1",
    "frontend_domain": "app.example.com",
    "api_domain": "api.example.com",
    "frontend_bucket_name": "openclaw-frontend-prod-YOUR_ACCOUNT_ID-us-east-1",
    "frontend_route53_zone_name": "example.com",
    "frontend_route53_zone_id": "YOUR_FRONTEND_ROUTE53_ZONE_ID",
    "api_route53_zone_name": "example.com",
    "api_route53_zone_id": "YOUR_API_ROUTE53_ZONE_ID",
    "broker_target_group_name": "openclaw-broker-prod",
    "broker_target_group_port": 3000,
    "broker_target_type": "ip",
    "broker_health_check_path": "/health",
    "api_listener_rule_priority": 210,
    "ecs_cluster": "YOUR_EXISTING_ECS_CLUSTER_NAME_OR_ARN",
    "private_subnet_ids": ["YOUR_PRIVATE_SUBNET_ID"],
    "alb_security_group_id": "YOUR_ALB_SECURITY_GROUP_ID",
    "openclaw_model": "openai/gpt-4.1-mini",
    "openclaw_gateway_protocol": "3",
    "openclaw_supabase_url": "https://YOUR_SUPABASE_PROJECT.supabase.co",
    "openclaw_supabase_anon_key": "YOUR_SUPABASE_ANON_KEY",
    "openclaw_credentials_table": "credential",
    "openclaw_control_ui_allowed_origins": "https://app.example.com,https://api.example.com",
    "openclaw_gateway_password_secret_arn": "arn:aws:secretsmanager:us-east-1:YOUR_ACCOUNT_ID:secret:openclaw/gateway-password",
    "openclaw_supabase_service_role_secret_arn": "arn:aws:secretsmanager:us-east-1:YOUR_ACCOUNT_ID:secret:openclaw/supabase-service-role",
    "openclaw_broker_base_url": "https://api.example.com",
    "openclaw_gateway_ws_origin": "https://app.example.com",
    "openclaw_broker_bearer_secret_arn": "arn:aws:secretsmanager:us-east-1:YOUR_ACCOUNT_ID:secret:openclaw/broker-bearer",
    "anthropic_api_key_secret_arn": "arn:aws:secretsmanager:us-east-1:YOUR_ACCOUNT_ID:secret:openclaw/anthropic-api-key",
    "openai_api_key_secret_arn": "arn:aws:secretsmanager:us-east-1:YOUR_ACCOUNT_ID:secret:openclaw/openai-api-key",
    "broker_mode": "queue",
    "broker_command": [],
    "ecs_task_cpu": 1024,
    "ecs_task_memory": 2048,
    "broker_service_desired_count": 1,
    "gateway_service_desired_count": 1,
    "worker_default_desired_count": 0,
    "worker_default_min_count": 0,
    "worker_default_max_count": 10,
    "terraform_lock_table_name": "YOUR_EXISTING_OPENCLAW_TERRAFORM_LOCK_TABLE",
    "artifacts_bucket_name": "openclaw-artifacts-prod-YOUR_ACCOUNT_ID-us-east-1",
    "artifacts_lifecycle_rule_id": "expire-prod-artifacts",
    "gateway_discovery_namespace_name": "openclaw-prod.local",
    "gateway_discovery_namespace_description": "Private DNS namespace for OpenClaw services (prod)",
    "gateway_discovery_service_name": "openclaw-gateway",
    "broker_log_group_name": "/ecs/openclaw-broker-prod",
    "gateway_log_group_name": "/ecs/openclaw-gateway-prod",
    "gateway_standalone_log_group_name": "/ecs/openclaw-gateway-standalone-prod",
    "broker_security_group_name": "openclaw-broker-service-prod",
    "gateway_security_group_name": "openclaw-gateway-service-prod",
    "state_efs_creation_token": "openclaw-state-prod",
    "state_efs_security_group_name": "openclaw-state-efs-prod",
    "broker_task_execution_role_name": "openclaw-ecs-task-execution-prod",
    "broker_task_execution_secrets_policy_name": "openclaw-ecs-task-execution-secrets-prod",
    "broker_task_role_name": "openclaw-ecs-task-prod",
    "broker_task_queue_policy_name": "openclaw-ecs-task-broker-queue-mode-prod",
    "broker_task_family": "openclaw-broker-prod",
    "broker_service_name": "openclaw-broker-prod",
    "gateway_task_family": "openclaw-gateway-prod",
    "gateway_service_name": "openclaw-gateway-prod",
    "worker_log_group_name": "/ecs/openclaw-worker-default-prod",
    "worker_gateway_log_group_name": "/ecs/openclaw-gateway-worker-default-prod",
    "worker_security_group_name": "openclaw-worker-default-service-prod",
    "worker_task_execution_role_name": "openclaw-ecs-task-execution-worker-default-prod",
    "worker_task_execution_secrets_policy_name": "openclaw-ecs-task-execution-worker-default-secrets-prod",
    "worker_task_role_name": "openclaw-ecs-task-worker-default-prod",
    "worker_task_policy_name": "openclaw-ecs-task-worker-default-prod",
    "worker_task_family": "openclaw-worker-default-prod",
    "worker_service_name": "openclaw-worker-default-prod",
    "worker_scale_out_policy_name": "openclaw-worker-default-scale-out-prod",
    "worker_scale_in_policy_name": "openclaw-worker-default-scale-in-prod",
    "worker_queue_scale_out_alarm_name": "openclaw-worker-default-queue-scale-out-prod",
    "worker_queue_scale_in_alarm_name": "openclaw-worker-default-queue-scale-in-prod",
    "frontend_oac_name": "openclaw-frontend-oac-prod"
  },
  "runtime_pointers": {
    "broker_image_param": "/openclaw/prod/broker_image_uri",
    "gateway_image_param": "/openclaw/prod/gateway_image_uri",
    "broker_protocol_param": "/openclaw/prod/broker_protocol_json",
    "gateway_protocol_param": "/openclaw/prod/gateway_protocol_json"
  },
  "deploy_lock": {
    "table": "YOUR_EXISTING_OPENCLAW_TERRAFORM_LOCK_TABLE",
    "lock_id": "openclaw/prod/terraform-apply"
  }
}
