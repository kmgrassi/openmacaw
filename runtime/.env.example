# Runtime orchestrator/launcher environment.
#
# The start scripts load the first file found of:
#   runtime/apps/orchestrator/.env, runtime/.env
#
# REQUIRED for database-backed behavior (work items, manager/planner flows,
# message log). Use the same values as platform/.env.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
